{
  "name": "scope-recall-openclaw",
  "version": "1.0.14",
  "description": "Scoped long-term memory for OpenClaw with SQLite truth, hybrid recall, rebuildable vectors, safe capture, and native-free fallbacks",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "DESIGN.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "cli.ts",
    "dist/",
    "docs/",
    "index.ts",
    "openclaw.plugin.json",
    "scripts/smoke-vector-repair.mjs",
    "skills/",
    "src/"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "smoke:vector-repair": "node scripts/smoke-vector-repair.mjs",
    "release:gate": "node scripts/release-gate.mjs"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "scope-recall",
    "sql-truth",
    "lancedb",
    "vector-search",
    "bm25",
    "hybrid-retrieval",
    "rerank",
    "ai-memory",
    "long-term-memory",
    "chunking",
    "long-context"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/410979729/scope-recall-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/410979729/scope-recall-openclaw/issues"
  },
  "homepage": "https://github.com/410979729/scope-recall-openclaw#readme",
  "author": "win4r",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48",
    "apache-arrow": "18.1.0",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "openai": "^6.21.0",
    "proper-lockfile": "^4.1.2"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "scope-recall-openclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.2"
    },
    "compat": {
      "pluginApi": ">=2026.6.2",
      "minGatewayVersion": "2026.6.2"
    },
    "build": {
      "openclawVersion": "2026.6.2",
      "pluginSdkVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true,
      "bundleRuntimeDependencies": false
    }
  }
}
